PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string (replace with your cluster URL)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/heart-disease-detector?retryWrites=true&w=majority

# Long random string – generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# URL of the deployed Python ML server (e.g. Render service URL)
ML_API_URL=https://your-ml-server.onrender.com

# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://your-frontend.vercel.app
